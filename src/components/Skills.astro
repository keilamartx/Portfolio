---
import SkillBadge from './SkillBadge.astro';

const development = ["Python", "HTML5 & CSS3", "JavaScript", "PHP", "Git"];
const security = ["Kali Linux", "Wireshark", "Nmap", "VirtualBox", "SQL", "Azure"];
const tools = ["Excel", "WordPress", "Power BI", "Figma", "Blender"];
---

<section id="habilidades" class="max-w-6xl mx-auto px-8 py-24">
  <div class="mb-16">
    <h2 class="text-4xl font-black text-text dark:text-light tracking-tighter">
      HABILIDADES
    </h2>
    <div class="h-1 w-20 bg-blue mt-2"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
    <div>
      <h3 class="text-blue dark:text-blue-light font-mono text-lg mb-6 uppercase tracking-widest flex items-center gap-2">
        Desarrollo
      </h3>
      <div class="flex flex-wrap gap-3">
        {development.map((skill) => <SkillBadge name={skill} />)}
      </div>
    </div>

    <div>
      <h3 class="text-blue dark:text-blue-light font-mono text-lg mb-6 uppercase tracking-widest flex items-center gap-2">
        Seguridad y Análisis
      </h3>
      <div class="flex flex-wrap gap-3">
        {security.map((skill) => <SkillBadge name={skill} />)}
      </div>
    </div>

    <div>
      <h3 class="text-blue dark:text-blue-light font-mono text-lg mb-6 uppercase tracking-widest flex items-center gap-2">
         Herramientas
      </h3>
      <div class="flex flex-wrap gap-3">
        {tools.map((skill) => <SkillBadge name={skill} />)}
      </div>
    </div>
  </div>
</section>