---
interface Props {
  name: string;
}
const { name } = Astro.props;
---
<div class="flex items-center gap-2 px-4 py-2 rounded-xl border border-green/50 dark:border-green/50 bg-white/5 backdrop-blur-md transition-all duration-300 hover:border-blue/50 hover:bg-blue/5 group">
  <span class="text-sm font-medium text-text dark:text-light group-hover:text-blue dark:group-hover:text-blue-light transition-colors">
    {name}
  </span>
</div>