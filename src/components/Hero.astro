---
const saludo = "Hola:) soy";
const nombre = "Keila Martinez";
const especialidad = "Ingeniera de Software | AI & Ciencia de Datos";
---

<section class="flex flex-col items-center justify-center min-h-[80vh] text-center px-4">
  <div class="space-y-5">
    <p class="text-color-text dark:text-green-light font-mono tracking-widest uppercase text-sm">
      {saludo}
    </p>
    
    <h1 class="text-5xl md:text-7xl font-bold text-blue dark:text-green-light">
        {nombre}
    </h1>
    
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-blue dark:text-slate-300">
      {especialidad}
    </p>

    <div class="flex gap-4 justify-center mt-10">
      <a href="#proyectos" class="px-6 py-3 bg-green-light/60 text-blue rounded-lg hover:bg-green-light/80 transition-all dark:text-white">
        Ver Proyectos
      </a>
      <a href="/cv.pdf" class="px-6 py-3 border-2 border-blue text-blue rounded-lg animate-cursed-pulse hover:bg-blue/10 transition-all dark:text-white dark:hover:bg-blue/20">
        Descargar CV
      </a>
    </div>
  </div>
</section>