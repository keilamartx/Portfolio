---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link?: string; // Enlace de cada proyecto
  projectUrl?: string; // Enlace de la tarjeta (Demo)
  showArrow?: boolean;
}

const { title, description, tags, link, projectUrl, showArrow = true } = Astro.props;
---

<div class="group relative p-8 rounded-2xl border border-slate-200 dark:border-white/10 bg-white/5 backdrop-blur-xl transition-all duration-500 hover:-translate-y-2 hover:border-green/50  hover:shadow-[0_0_30px_rgba(25,91,138,0.2)] overflow-hidden flex flex-col h-full">

  {projectUrl && (
    <a href={projectUrl} target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-10">
      <span class="sr-only">Ver detalles del proyecto {title}</span>
    </a>
  )}

  <div class="absolute -inset-px bg-gradient-to-br from-blue/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

  <div class="relative z-20 flex flex-col h-full pointer-events-none">
    <div class="flex justify-between items-start mb-4">
      <h3 class="text-xl font-bold text-text text-slate-900 dark:text-white group-hover:text-blue dark:group-hover:text-green transition-colors">
        {title}
      </h3>
      {showArrow && (
      <div class="text-blue dark:text-green opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
      </div>
      )}
    </div>
    
    <p class="text-slate-600 dark:text-slate-400 text-sm mb-6 leading-relaxed flex-grow">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-8">
      {tags.map((tag) => (
        <span class="px-2 py-1 text-[10px] font-mono font-medium rounded bg-blue/5 text-blue-dark dark:text-blue-light border border-blue/10">
          {tag}
        </span>
      ))}
    </div>

    {link && (
      <div class="mt-auto relative z-30 pointer-events-auto">
        <a 
          href={link} 
          target="_blank" 
          rel="noopener noreferrer"
          class="flex flex-row items-center justify-center gap-2 px-4 py-2.5 bg-blue text-light rounded-lg font-bold text-[10px] uppercase tracking-widest transition-all duration-300 hover:bg-[#154a70] active:scale-95 shadow-md shadow-blue/20 whitespace-nowrap"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
            <path d="M9 18c-4.51 2-4.51-2-7-2"></path>
          </svg>
          Repo
        </a>
      </div>
    )}
  </div>
</div>